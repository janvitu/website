---
import { getT } from "@/i18n/getT";

const t = getT(Astro.currentLocale);

const contactURL = "/contact/";
---

<section class="pt-24 pb-48 text-center">
	<span class="text-base md:text-2xl lg:text-3xl text-accent"
		>Make it real.</span
	>
	<h2 class="text-center">One story. One motion.</h2>
	<span class="text-[clamp(1.5rem,4.5vw,3.75rem)]">
		<a
			href={contactURL}
			class="inline-block font-bold underline hover:cursor-pointer hover:text-accent transition-colors duration-300 focus-accent"
			>{t("contact-footer.link-text", "Let's collaborate!")}</a
		>
	</span>
</section>
