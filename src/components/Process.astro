---
import { getT } from "@/i18n/getT";
import { process } from "@/data/process";
import CubesStacked from "./svg/CubesStacked.astro";
import MagnifyingGlass from "./svg/MagnifyingGlass.astro";
import Progress from "./svg/Progress.astro";
import Shapes from "./svg/Shapes.astro";
import Timeline from "./svg/Timeline.astro";
import BinaryCheck from "./svg/BinaryCheck.astro";

const t = getT(Astro.currentLocale);

const iconMap: Record<string, (_props: Record<string, unknown>) => unknown> = {
	"svg/CubesStacked.svg": CubesStacked,
	"svg/MagnifyingGlass.svg": MagnifyingGlass,
	"svg/Progress.svg": Progress,
	"svg/Shapes.svg": Shapes,
	"svg/Timeline.svg": Timeline,
	"svg/BinaryCheck.svg": BinaryCheck,
};
---

<section class="base-grid py-20">
	<h2
		class="col-start-3 col-end-12 text-right text-5xl font-black sm:text-6xl md:text-8xl lg:col-end-10"
	>
		{t("project-process-heading", "How I handle a project")}
	</h2>
	<div
		class="col-span-full mt-10 grid grid-cols-1 gap-px bg-neutral-900 md:grid-cols-2 lg:grid-cols-3"
	>
		{
			process.map((step) => {
				const Icon = iconMap[step.icon];
				return (
					<div class="bg-amber-300 p-8">
						<div class="md:h-[280px]">
							<div class="w-20 fill-neutral-800 pb-10 md:w-36 md:pt-14 md:pb-20">
								{Icon && <Icon />}
							</div>
						</div>
						<div class="flex items-end space-x-4">
							<span class="grid aspect-square h-10 place-items-center rounded-full bg-neutral-800 p-1 text-neutral-100">
								{step.id}
							</span>
							<span class="block text-xl font-bold">{step.heading}</span>
						</div>
						{step.text.map((paragraph) => (
							<p class="mt-6">{paragraph}</p>
						))}
					</div>
				);
			})
		}
	</div>
</section>
