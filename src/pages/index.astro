---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactFooter from "@/components/ContactFooter.astro";
import ArrowLink from "@/components/ArrowLink.astro";
import { getT } from "@/i18n/getT";

const t = getT(Astro.currentLocale);
---

<BaseLayout
	title={t("home.title", "Jan Vítů — Product builder & growth strategist")}
	description={t(
		"home.description",
		"I help brands find focus, build the right strategy, and turn ambitious bets into measurable results.",
	)}
>
	<!-- Hero -->
	<section class="relative h-screen">
		<img
			src="/images/wave.avif"
			alt=""
			aria-hidden="true"
			class="absolute -right-16 top-[30vh] w-full md:top-28 md:-right-24 md:w-2/3 object-contain mix-blend-multiply pointer-events-none"
		/>
		<div class="grid h-full grid-cols-12 pt-[32vh] pb-[10vh]">
			<div
				class="col-start-2 row-start-1 mt-[5vh] whitespace-nowrap md:col-start-3"
			>
				<span class="block whitespace-nowrap text-lg font-light md:text-5xl">
					Hi, I'm Jan
				</span>
				<h1>
					<span class="text-accent">Curious</span> by nature.<br />
					<span class="font-black">Relentless about outcomes.</span>
				</h1>
			</div>
			<p
				class="col-start-2 row-start-2 col-end-12 md:col-end-8 md:col-start-3 text-[clamp(1.125rem,2vw,1.5rem)]"
			>
				I <b>chase bold ideas</b>, help people & products to
				<b>spark growth</b> and lasting value.
			</p>
		</div>
		<div
			id="scroll-indication"
			class="absolute inset-x-0 bottom-6 grid place-content-center items-center text-sm sm:bottom-4"
		>
			<span>Scroll down</span>
			<div class="mx-auto mt-4 h-16 w-[2px] bg-neutral-800"></div>
		</div>
	</section>

	<!-- Bold ideas section -->
	<section>
		<div class="relative grid grid-cols-12 pt-24 md:pt-48">
			<h2 class="col-start-2 col-end-12 md:col-start-3 md:col-end-9">
				<span class="font-black">Bold</span> ideas need more than
				<span class="text-accent">passion</span>
			</h2>
			<p
				class="col-start-3 col-end-12 row-start-2 mt-4 text-xl text-neutral-700 sm:text-2xl md:col-start-4 md:col-end-9 md:mt-10 md:text-3xl"
			>
				They need a <span class="text-accent">strategy</span> to turn them into
				<b class="text-neutral-900">outcomes</b>.
			</p>
			<p
				class="col-start-3 col-end-12 row-start-3 mt-2 text-sm text-neutral-600 sm:text-base md:col-start-4 md:col-end-9 md:mt-5 md:text-xl"
			>
				Strategy turns passion into direction. And direction is what makes ideas
				last.
			</p>
			<div class="col-start-2 col-end-12 row-start-4 mt-5 whitespace-nowrap md:col-start-4 md:col-end-9 md:mt-10 md:text-3xl">
				<ArrowLink href="/work" label="See my work" />
			</div>
			<div
				class="col-start-2 col-end-12 row-start-5 mt-5 whitespace-nowrap md:col-start-4 md:col-end-9 md:mt-10 md:text-3xl"
			>
				<span
					class="text-sm font-bold text-neutral-900 sm:text-base md:col-start-4 md:col-end-9 md:mt-5 md:text-xl"
					>brands I've been part of:</span
				>
			</div>
			<div
				class="col-start-2 col-end-12 row-start-6 mt-10 md:col-start-4 md:col-end-9"
			>
				<div class="w-full">
					<div class="flex flex-wrap gap-6 xl:gap-8 xl:flex-nowrap">
						<img
							src="/logos/underliner.svg"
							alt="Underliner studio"
							class="h-6 md:h-8 inline-block"
						/>
						<img
							src="/logos/adprint.svg"
							alt="AdPrint"
							class="h-6 md:h-8 inline-block"
						/>
						<img
							src="/logos/tridora.svg"
							alt="Tridora"
							class="h-6 md:h-8 inline-block"
						/>
						<img
							src="/logos/fiewo.svg"
							alt="Fiewo"
							class="h-6 md:h-8 inline-block"
						/>
						<img
							src="/logos/deepscout.svg"
							alt="DeepScout"
							class="h-6 md:h-8 inline-block"
						/>
						<img
							src="/logos/juicymo.svg"
							alt="Juicymo"
							class="h-6 md:h-8 inline-block"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Focus section -->
	<section>
		<div class="relative grid grid-cols-12 pt-24 md:pt-48">
			<h2 class="col-start-2 col-end-12 md:col-start-3 md:col-end-9">
				Most teams don't lack <span class="text-accent">ideas</span>
			</h2>
			<p
				class="col-start-3 col-end-12 row-start-2 mt-4 text-xl text-neutral-700 sm:text-2xl md:col-start-4 md:col-end-9 md:mt-10 md:text-3xl"
			>
				They lack the <b class="text-neutral-900">focus</b> to pick the right ones
				and the nerve to cut the rest.
			</p>
			<p
				class="col-start-3 col-end-12 row-start-3 mt-2 text-sm text-neutral-600 sm:text-base md:col-start-4 md:col-end-9 md:mt-5 md:text-xl"
			>
				When focus and courage come together, the right ideas survive, the hard
				calls get made and ambition becomes something real.
			</p>
			<div
				class="col-start-2 col-end-12 row-start-4 mt-5 whitespace-nowrap md:col-start-4 md:col-end-9 md:mt-10 md:text-3xl"
			>
				<ArrowLink href="/about" label="About me" />
			</div>
			<div
				class="col-start-4 col-end-12 md:col-start-9 md:col-end-12 md:row-span-4 md:px-4"
			>
				<svg
					width="100%"
					height="100%"
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 962.52 861.3"
				>
					<g id="Layer_1-2" data-name="Layer 1">
						<polygon
							style="fill: var(--color-neutral-300, #d4d4d4); stroke-width: 0"
							points="662.52 711.3 0 711.3 85.67 561.3 331.26 131.31 406.26 0 556.26 0 481.26 131.31 406.26 262.63 235.67 561.3 576.85 561.3 662.52 711.3"
						></polygon>
						<polygon
							style="fill: var(--color-neutral-600, #525252); stroke-width: 0"
							points="962.52 711.3 898.19 861.3 726.85 561.3 556.26 262.63 481.26 393.94 385.67 561.3 235.67 561.3 406.26 262.63 481.26 131.31 556.26 0 631.26 131.31 876.85 561.3 962.52 711.3"
						></polygon>
						<polygon
							style="fill: var(--color-neutral-800, #262626); stroke-width: 0"
							points="898.19 861.3 64.33 861.3 0 711.3 662.52 711.3 576.85 561.3 481.26 393.94 556.26 262.63 726.85 561.3 898.19 861.3"
						></polygon>
					</g>
				</svg>
			</div>
		</div>
	</section>

	<!-- Purpose section -->
	<section>
		<div class="grid grid-cols-12 py-24 md:py-32 md:pt-48">
			<h2 class="col-start-2 col-end-12 md:col-start-4 md:col-end-10">
				Great results need a greater purpose
			</h2>
			<div
				class="col-start-3 col-end-12 row-start-2 mt-2 text-sm text-neutral-600 sm:text-base md:col-start-5 md:col-end-10 md:mt-5 md:text-xl space-y-1 md:space-y-2"
			>
				<p>Results don't come from pressure. They come from people.</p>
				<p>
					People who believe in what they are building. People who believe they
					can make the difference.
				</p>
				<p>
					That belief creates space. To grow, to share, to think sharper and
					clearer.
				</p>
				<p>That's not just a strategy. That's a mission worth having.</p>
			</div>
		</div>
	</section>

	<ContactFooter />
</BaseLayout>
