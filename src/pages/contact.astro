---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useT } from "@/i18n/getT";

const t = useT(Astro);
---

<BaseLayout
	title={t("contact.title", "Contact | Jan Vítů")}
	description={t(
		"contact.description",
		"Let's start something bold together. Reach out to Jan Vítů.",
	)}
>
	<section
		class="base-grid min-h-[100svh] place-content-center pb-12 pt-60 md:pb-24"
	>
		<h1 class="col-start-2 col-end-11 md:col-start-3">
			Let's start something<br />
			<span class="font-black text-accent">bold</span> together
		</h1>
		<p
			class="col-start-2 col-end-12 row-start-2 mt-4 text-sm text-neutral-700 sm:text-xl md:col-start-4 md:mt-10 md:text-2xl xl:col-end-10"
		>
			The kind of work people remember comes from connection. Reach out
			at&nbsp;—
			<a
				id="copyitem"
				role="button"
				tabindex="0"
				class="font-bold text-neutral-900 underline hover:cursor-pointer focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
				>jan@underliner.studio</a
			><span class="align-middle text-xs text-neutral-400"
				>&nbsp;(click&nbsp;to&nbsp;copy)</span
			>
			– and let's make it happen.
		</p>
	</section>

	<script>
		import { copyContent } from "@/scripts/utils";

		const copyElement = document.getElementById("copyitem");
		copyElement?.addEventListener("click", copyContent as EventListener);
		copyElement?.addEventListener("keydown", (e: KeyboardEvent) => {
			if (e.key === "Enter" || e.key === " ") {
				copyContent(e as unknown as MouseEvent);
			}
		});
	</script>
</BaseLayout>
