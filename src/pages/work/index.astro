---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactFooter from "@/components/ContactFooter.astro";
import WorkCard from "@/components/WorkCard.astro";
---

<BaseLayout
	title="Jan Vítů — Work"
	description="Show up. Do the work. Own the outcome."
>
	<section class="relative min-h-svh">
		<div class="base-grid pt-[38vh] pb-[20vh]">
			<div
				class="col-start-2 col-end-12 md:col-start-3 md:col-end-11 text-center"
			>
				<h1 class="font-black leading-none">
					Show up.<br />
					Do the work.<br />
					Own the outcome.
				</h1>
				<p class="mt-8 text-xl text-neutral-600 md:text-2xl">
					As someone with <span class="font-medium">skin in the game</span>, I
					get in the work with you.
				</p>
			</div>
		</div>
		<div
			id="scroll-indication"
			class="absolute inset-x-0 bottom-6 grid place-content-center items-center text-sm sm:bottom-4"
		>
			<span>Scroll down</span>
			<div class="mx-auto mt-4 h-16 w-[2px] bg-neutral-800"></div>
		</div>
	</section>

	<section class="py-24 md:py-32">
		<div class="base-grid">
			<blockquote
				class="col-start-2 col-end-12 md:col-start-4 md:col-end-10 text-center backdrop-blur-xl bg-white/20 border border-white/70 shadow-xl shadow-black/5 ring-1 ring-inset ring-white/50 px-12 py-16 md:px-16 md:py-24"
			>
				<p
					class="text-2xl font-extralight italic leading-relaxed md:text-4xl md:leading-relaxed"
				>
					"Great products do not happen by accident. They need the right focus
					at the right time and someone willing to make the hard calls."
				</p>
			</blockquote>
		</div>
	</section>

	<section class="pb-24 md:pb-32">
		<div class="base-grid">
			<div class="col-start-2 col-end-12 mb-12 md:col-start-3 md:col-end-11">
				<h2 class="font-black text-3xl md:text-4xl leading-tight">
					The right focus at the right stage<br />
					changes everything.
				</h2>
				<p class="mt-3 text-xl text-neutral-600 md:text-2xl">
					From idea to traction.
				</p>
			</div>

			<div
				class="col-start-2 col-end-12 grid grid-cols-1 gap-4 md:grid-cols-3 md:items-end"
			>
				<WorkCard
					href="/work/gtm"
					image="/images/mountain.avif"
					title="Go To Market"
					description="Not a launch plan. The system that makes product, marketing, and sales compound as one."
					label="Explore GTM"
				/>
				<WorkCard
					href="/work/product"
					image="/images/iceberg.avif"
					title="Product"
					description="Discover what matters. Ship what works. Repeat until it compounds."
					label="Explore product work"
					elevated
				/>
				<WorkCard
					href="/work/marketing"
					image="/images/mist.avif"
					title="Marketing"
					description="Not louder. Remarkable. Marketing that earns trust, not just attention."
					label="Explore marketing"
				/>
			</div>
		</div>
	</section>

	<section class="pb-32 md:pb-48">
		<div class="base-grid">
			<div
				class="col-start-2 col-end-12 space-y-6 text-lg md:text-xl max-w-[50ch] text-center mx-auto leading-relaxed"
			>
				<p>
					I believe <span class="font-medium">bold ideas</span> are worth chasing.
					Even when they are hard. And especially when they are hard.
				</p>
				<p>
					I believe building something real requires <span class="font-medium"
						>the courage to be wrong</span
					>, <span class="font-medium">the focus to cut what does not work</span
					>, and <span class="font-medium"
						>the relentless pursuit of what actually matters</span
					>.
				</p>
				<p>
					I commit to telling you the truth. Making the hard calls. Staying in
					the work until something worth believing in is built.
				</p>
				<p class="font-light">
					My mission is to inspire people to do what inspires them so that
					together we can build a world worth believing in.
				</p>
			</div>
		</div>
	</section>
	<ContactFooter />
</BaseLayout>
