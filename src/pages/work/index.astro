---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArrowLink from "@/components/ArrowLink.astro";
---

<BaseLayout
	title="Jan Vítů — Work"
	description="Show up. Do the work. Own the outcome."
>
	<section class="min-h-[100svh]">
		<div class="base-grid pt-[38vh] pb-[20vh]">
			<div class="col-start-2 col-end-12 md:col-start-3 md:col-end-11">
				<h1 class="font-black leading-none">
					Show up.<br />
					Do the work.<br />
					Own the outcome.
				</h1>
				<p class="mt-8 text-xl text-neutral-600 md:text-2xl">
					As someone with skin in the game, I own what happens next.
				</p>
			</div>
		</div>
	</section>

	<section class="pb-24 md:pb-32">
		<div class="base-grid">
			<div class="col-start-2 col-end-12 grid grid-cols-1 gap-4 md:grid-cols-3">

				<!-- Product -->
				<div class="relative overflow-hidden min-h-[480px] backdrop-blur-xl bg-white/20 border border-white/70 shadow-xl shadow-black/5 ring-1 ring-inset ring-white/50">
					<img
						src="/images/iceberg.avif"
						alt=""
						aria-hidden="true"
						class="absolute inset-0 h-full w-full object-contain object-top mix-blend-multiply"
					/>
					<div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-white/60 to-transparent"></div>
					<div class="absolute inset-x-0 bottom-0 z-10 p-8">
						<h2 class="text-2xl font-black uppercase tracking-tight md:text-3xl">
							Product
						</h2>
						<p class="mt-2 text-neutral-600">
							Discovery to delivery. Operating model. Culture that sticks.
						</p>
						<ArrowLink href="/work/product" label="Explore product work" />
					</div>
				</div>

				<!-- GTM -->
				<div class="relative overflow-hidden min-h-[480px] backdrop-blur-xl bg-white/20 border border-white/70 shadow-xl shadow-black/5 ring-1 ring-inset ring-white/50">
					<img
						src="/images/mountain.avif"
						alt=""
						aria-hidden="true"
						class="absolute inset-0 h-full w-full object-contain object-top mix-blend-multiply"
					/>
					<div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-white/60 to-transparent"></div>
					<div class="absolute inset-x-0 bottom-0 z-10 p-8">
						<h2 class="text-2xl font-black uppercase tracking-tight md:text-3xl">
							Go To Market
						</h2>
						<p class="mt-2 text-neutral-600">
							One ecosystem. Not three teams pointing at each other.
						</p>
						<ArrowLink href="/work/gtm" label="Explore GTM" />
					</div>
				</div>

				<!-- Marketing -->
				<div class="relative overflow-hidden min-h-[480px] backdrop-blur-xl bg-white/20 border border-white/70 shadow-xl shadow-black/5 ring-1 ring-inset ring-white/50">
					<img
						src="/images/mist.avif"
						alt=""
						aria-hidden="true"
						class="absolute inset-0 h-full w-full object-contain object-top mix-blend-multiply"
					/>
					<div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-white/60 to-transparent"></div>
					<div class="absolute inset-x-0 bottom-0 z-10 p-8">
						<h2 class="text-2xl font-black uppercase tracking-tight md:text-3xl">
							Marketing
						</h2>
						<p class="mt-2 text-neutral-600">
							Strategy and execution. The connective tissue that runs through
							everything.
						</p>
						<ArrowLink href="/work/marketing" label="Explore marketing" />
					</div>
				</div>

			</div>
		</div>
	</section>
</BaseLayout>
