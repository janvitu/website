---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactFooter from "@/components/ContactFooter.astro";
import WorkCard from "@/components/WorkCard.astro";
---

<BaseLayout
	title="Jan Vitu — Marketing"
	description="Not louder. Remarkable. Marketing that earns trust, not just attention."
>
	<!-- Hero — centered, mist as contained atmosphere -->
	<section class="relative h-screen">
		<img
			src="/images/mist.avif"
			alt=""
			aria-hidden="true"
			class="absolute inset-0 h-full w-full object-contain object-top mix-blend-multiply pointer-events-none"
		/>
		<div class="base-grid relative place-items-center h-full">
			<div
				class="col-start-2 col-end-12 md:col-start-3 md:col-end-11 text-center"
			>
				<span
					class="block text-xs font-bold uppercase tracking-[0.2em] text-accent mb-4 md:mb-6"
					>Marketing</span
				>
				<h1 class="font-black leading-none text-[clamp(2.5rem,10vw,10rem)]">
					Not louder.<br />
					<span class="text-accent">Remarkable.</span>
				</h1>
				<p
					class="mt-6 max-w-[40ch] mx-auto text-lg text-neutral-600 md:text-2xl"
				>
					Marketing that earns trust, not just attention.
				</p>
			</div>
		</div>
	</section>

	<!-- The contrast -->
	<section>
		<div class="base-grid py-32 md:py-48">
			<h2 class="col-start-2 col-end-12 md:col-start-3 md:col-end-9">
				Most marketing <span class="text-accent">interrupts</span>
			</h2>
			<p
				class="col-start-3 col-end-12 row-start-2 mt-4 text-xl text-neutral-700 sm:text-2xl md:col-start-4 md:col-end-9 md:mt-10 md:text-3xl"
			>
				The kind worth doing <b class="text-neutral-900">earns permission</b>.
			</p>
			<div
				class="col-start-3 col-end-12 row-start-3 mt-6 md:col-start-4 md:col-end-9 space-y-2 md:space-y-4"
			>
				<p class="text-sm text-neutral-700 sm:text-base md:text-xl">
					More ads, more channels, more noise. That is the default playbook. And
					it is exhausting - for the team and for the audience.
				</p>
				<p class="text-sm text-neutral-700 sm:text-base md:text-xl">
					There is a different way. Instead of fighting for attention, earn it.
					Instead of reaching everyone, matter to someone.
				</p>
			</div>
		</div>
	</section>

	<!-- Principles — manifesto style, alternating alignment -->
	<section>
		<div class="base-grid pt-24 pb-12 md:pt-32">
			<h2 class="col-start-2 col-end-12 md:col-start-3 md:col-end-9">
				What I <span class="text-accent">believe</span>
			</h2>
		</div>

		<div class="base-grid pb-32 md:pb-48">
			<div
				class="col-start-2 col-end-12 md:col-start-3 md:col-end-11 space-y-20 md:space-y-32"
			>
				<div class="max-w-[55ch]">
					<h3
						class="text-3xl font-black leading-tight md:text-4xl md:leading-tight"
					>
						Find the smallest audience worth serving.
					</h3>
					<p class="mt-4 text-neutral-600 md:text-lg leading-relaxed">
						Not everyone needs to care. The right ten people who truly resonate
						with your story will do more than ten thousand who scroll past.
						Start small. Start specific. Earn the right to grow.
					</p>
				</div>

				<div class="max-w-[55ch] md:ml-auto">
					<h3
						class="text-3xl font-black leading-tight md:text-4xl md:leading-tight"
					>
						Be remarkable, not loud.
					</h3>
					<p class="mt-4 text-neutral-600 md:text-lg leading-relaxed">
						Remarkable means worth remarking on. It is not about volume or
						frequency - it is about making something people feel compelled to
						share. If the work does not spread on its own, more spend will not
						fix it.
					</p>
				</div>

				<div class="max-w-[55ch]">
					<h3
						class="text-3xl font-black leading-tight md:text-4xl md:leading-tight"
					>
						Trust is built in small moments.
					</h3>
					<p class="mt-4 text-neutral-600 md:text-lg leading-relaxed">
						Every touchpoint is a promise. The email, the landing page, the
						first interaction. Each one either builds trust or chips away at it.
						There are no neutral moments.
					</p>
				</div>

				<div class="max-w-[55ch] md:ml-auto">
					<h3
						class="text-3xl font-black leading-tight md:text-4xl md:leading-tight"
					>
						Stories move people. Tactics move metrics.
					</h3>
					<p class="mt-4 text-neutral-600 md:text-lg leading-relaxed">
						You need both. But if you start with the tactic, you get a campaign.
						If you start with the story, you get a movement. The best marketing
						makes people feel like they belong to something.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- What I do -->
	<section>
		<div class="base-grid py-32 md:py-48">
			<h2 class="col-start-2 col-end-12 md:col-start-3 md:col-end-9">
				What I <span class="text-accent">do</span>
			</h2>
			<div
				class="col-start-3 col-end-12 row-start-2 mt-8 md:col-start-4 md:col-end-9 md:mt-14 space-y-10 md:space-y-14"
			>
				<div>
					<h3 class="text-lg font-bold text-neutral-900 md:text-xl">
						Shape the narrative
					</h3>
					<p class="mt-2 text-neutral-600 md:text-lg leading-relaxed">
						Find the core story that connects what you build to why people care.
						Not a tagline - a point of view that runs through everything.
					</p>
				</div>
				<div>
					<h3 class="text-lg font-bold text-neutral-900 md:text-xl">
						Find the right audience
					</h3>
					<p class="mt-2 text-neutral-600 md:text-lg leading-relaxed">
						Define who you are really for. Not demographics - the people who
						will care enough to tell others. Then build around them.
					</p>
				</div>
				<div>
					<h3 class="text-lg font-bold text-neutral-900 md:text-xl">
						Build permission, not just reach
					</h3>
					<p class="mt-2 text-neutral-600 md:text-lg leading-relaxed">
						Channels and campaigns matter, but only when people want to hear
						from you. Earn attention first. Scale it second.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Closing -->
	<section class="py-24 md:py-32">
		<div class="base-grid">
			<blockquote
				class="col-start-2 col-end-12 md:col-start-4 md:col-end-10 text-center glass-card px-10 py-14 md:px-16 md:py-20"
			>
				<p
					class="text-2xl font-extralight italic leading-relaxed md:text-4xl md:leading-relaxed"
				>
					"People do not buy products. They buy the story they tell themselves
					about who they become."
				</p>
				<p class="mt-8 text-neutral-600 md:text-lg">
					Make that story worth telling.
				</p>
			</blockquote>
		</div>
	</section>

	<section class="py-24 md:py-32">
		<div class="base-grid">
			<div
				class="col-start-2 col-end-12 lg:col-start-3 lg:col-end-11 2xl:col-start-4 2xl:col-end-10 grid grid-cols-1 gap-4 md:grid-cols-2 items-end"
			>
				<WorkCard
					href="/work/gtm"
					image="/images/mountain.avif"
					title="Go To Market"
					description="Not a launch plan. The system that makes product, marketing, and sales compound as one."
					label="Explore GTM"
				/>
				<WorkCard
					href="/work/product"
					image="/images/iceberg.avif"
					title="Product"
					description="Discover what matters. Ship what works. Repeat until it compounds."
					label="Explore product work"
				/>
			</div>
		</div>
	</section>

	<ContactFooter />
</BaseLayout>
