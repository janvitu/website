---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactFooter from "@/components/ContactFooter.astro";
---

<BaseLayout
	title="Jan Vítů — Marketing"
	description="The intersection of a human need, a story, and the courage to act."
>
	<section class="relative h-screen">
		<img
			src="/images/mist.avif"
			alt=""
			aria-hidden="true"
			class="absolute inset-0 h-full w-full object-contain object-top mix-blend-multiply pointer-events-none mask-[linear-gradient(to_top,transparent_0%,black_60%)] [-webkit-mask-image:linear-gradient(to_top,transparent_0%,black_60%)]"
		/>
		<div class="base-grid relative h-full">
			<div
				class="col-start-2 col-end-12 md:col-start-4 md:col-end-10 flex flex-col items-center justify-center pt-[33.333vh] text-center"
			>
				<h1 class="font-black uppercase tracking-tight leading-none">
					Marketing
				</h1>
				<p class="mt-4 max-w-[40ch] text-xl text-neutral-600 md:text-2xl">
					The intersection of a human need, a story, and the courage to act.
				</p>
			</div>
		</div>
	</section>
</BaseLayout>

<ContactFooter />
