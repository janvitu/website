---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactFooter from "@/components/ContactFooter.astro";
import WorkCard from "@/components/WorkCard.astro";
---

<BaseLayout
	title="Jan Vitu — Product"
	description="Discover what matters. Ship what works. Repeat until it compounds."
>
	<!-- Hero — left-aligned, iceberg as atmosphere -->
	<section class="relative h-screen overflow-hidden">
		<img
			src="/images/iceberg.avif"
			alt=""
			aria-hidden="true"
			class="absolute -right-[5%] top-[22vh] w-[140%] md:top-12 md:right-0 md:w-1/2 md:max-h-[92vh] object-contain mix-blend-multiply pointer-events-none"
		/>
		<div
			class="base-grid relative h-full items-end pb-[14vh] md:items-center md:pb-0"
		>
			<div class="col-start-2 col-end-11 md:col-start-3 md:col-end-9">
				<span
					class="block text-xs font-bold uppercase tracking-[0.2em] text-accent mb-4 md:mb-6"
					>Product</span
				>
				<h1 class="font-black leading-none">
					Discover what matters.<br />
					<span class="text-accent">Ship what works.</span>
				</h1>
				<p class="mt-6 max-w-[45ch] text-lg text-neutral-600 md:text-2xl">
					Repeat until it compounds.
				</p>
			</div>
		</div>
	</section>
	<!-- The problem -->
	<section>
		<div class="base-grid py-32 md:py-48">
			<h2 class="col-start-2 col-end-12 md:col-start-3 md:col-end-9">
				Most teams ship <span class="text-accent">features</span>
			</h2>
			<p
				class="col-start-3 col-end-12 row-start-2 mt-4 text-xl text-neutral-700 sm:text-2xl md:col-start-4 md:col-end-9 md:mt-10 md:text-3xl"
			>
				The best teams ship <b class="text-neutral-900">outcomes</b>.
			</p>
			<div
				class="col-start-3 col-end-12 row-start-3 mt-6 md:col-start-4 md:col-end-9 space-y-2 md:space-y-4"
			>
				<p class="text-sm text-neutral-700 sm:text-base md:text-xl">
					Roadmaps full of features feel productive. But velocity without
					direction is just motion. The backlog grows, the team delivers, and
					somehow the needle does not move.
				</p>
				<p class="text-sm text-neutral-700 sm:text-base md:text-xl">
					The missing piece is rarely effort. <b>It is discovery.</b>
				</p>
			</div>
		</div>
	</section>

	<!-- The iceberg — descending layers with increasing left indent -->
	<section>
		<div class="base-grid py-24">
			<h2 class="col-start-2 col-end-12 md:col-start-3 md:col-end-9">
				What sits <b>beneath</b> the surface
			</h2>
			<p
				class="col-start-3 col-end-12 row-start-2 mt-4 text-xl text-neutral-700 sm:text-2xl md:col-start-4 md:col-end-9 md:mt-10 md:text-3xl"
			>
				Great products are built in layers.
			</p>
		</div>

		<div class="base-grid">
			<div class="col-start-2 col-end-12 md:col-start-4 md:col-end-9">
				<img
					src="/images/waterSurface.avif"
					alt=""
					aria-hidden="true"
					class="w-full opacity-30 mix-blend-multiply pointer-events-none mb-4"
				/>
				<!-- Surface — full width, bold accent -->
				<div class="border-l-2 border-accent pl-6 py-10 md:pl-10 md:py-14">
					<span
						class="block text-xs font-bold uppercase tracking-widest text-accent"
						>Surface</span
					>
					<h3 class="mt-2 text-2xl font-black md:text-3xl">
						The feature people see
					</h3>
					<p
						class="mt-3 max-w-[55ch] text-neutral-600 md:text-lg leading-relaxed"
					>
						What the user interacts with. The screen, the flow, the moment of
						value. This is what most teams obsess over - and ship too early.
					</p>
				</div>

				<!-- Below — indented, faded -->
				<div class="border-l-2 border-neutral-300 pl-6 py-10 md:pl-10 md:py-14">
					<span
						class="block text-xs font-bold uppercase tracking-widest text-neutral-400"
						>Below</span
					>
					<h3 class="mt-2 text-2xl font-black md:text-3xl">
						The problem worth solving
					</h3>
					<p
						class="mt-3 max-w-[55ch] text-neutral-600 md:text-lg leading-relaxed"
					>
						Not every pain point deserves a solution. Continuous discovery means
						talking to real customers, mapping their opportunities, and making
						hard bets on which problems actually move the business.
					</p>
				</div>

				<!-- Deep — more indented, most faded -->
				<div class="border-l-2 border-neutral-200 pl-6 py-10 md:pl-10 md:py-14">
					<span
						class="block text-xs font-bold uppercase tracking-widest text-neutral-300"
						>Deep</span
					>
					<h3 class="mt-2 text-2xl font-black md:text-3xl">
						The team that owns it
					</h3>
					<p
						class="mt-3 max-w-[55ch] text-neutral-600 md:text-lg leading-relaxed"
					>
						Empowered teams do not wait for instructions. They understand the
						mission, have context on the customer, and own the outcome - not
						just the output. This is where compounding starts.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- What I do — 2x2 grid -->
	<section>
		<div class="base-grid py-32 md:py-48">
			<h2 class="col-start-2 col-end-12 md:col-start-3 md:col-end-9">
				What I <span class="text-accent">do</span>
			</h2>
			<div
				class="col-start-2 col-end-12 row-start-2 mt-12 md:mt-20 grid grid-cols-1 gap-10 md:grid-cols-2 md:gap-x-12 md:gap-y-14 md:col-start-3 md:col-end-11"
			>
				<div>
					<h3 class="text-lg font-bold text-neutral-900 md:text-xl">
						Shape the discovery habit
					</h3>
					<p class="mt-2 text-neutral-600 md:text-lg leading-relaxed">
						Build a continuous loop of customer conversations, opportunity
						mapping, and assumption testing. Not a phase - a practice the team
						runs every week.
					</p>
				</div>
				<div>
					<h3 class="text-lg font-bold text-neutral-900 md:text-xl">
						Align around outcomes
					</h3>
					<p class="mt-2 text-neutral-600 md:text-lg leading-relaxed">
						Replace feature-driven roadmaps with outcome-driven bets. Clear
						success metrics, clear ownership, clear accountability for what
						actually moved.
					</p>
				</div>
				<div>
					<h3 class="text-lg font-bold text-neutral-900 md:text-xl">
						Empower the team
					</h3>
					<p class="mt-2 text-neutral-600 md:text-lg leading-relaxed">
						Give teams the context, the autonomy, and the trust to solve
						problems their own way. The best product decisions happen closest to
						the customer.
					</p>
				</div>
				<div>
					<h3 class="text-lg font-bold text-neutral-900 md:text-xl">
						Close the loop
					</h3>
					<p class="mt-2 text-neutral-600 md:text-lg leading-relaxed">
						Ship, measure, learn, adapt. Every cycle sharpens the team's
						instinct. Every iteration gets closer to what actually matters.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Closing -->
	<section class="py-24 md:py-32">
		<div class="base-grid">
			<blockquote
				class="col-start-2 col-end-12 md:col-start-4 md:col-end-10 text-center glass-card px-10 py-14 md:px-16 md:py-20"
			>
				<p
					class="text-2xl font-extralight italic leading-relaxed md:text-4xl md:leading-relaxed"
				>
					"Fall in love with the problem, not the solution."
				</p>
				<p class="mt-8 text-neutral-600 md:text-lg">The rest is iteration.</p>
			</blockquote>
		</div>
	</section>

	<section class="py-24 md:py-32">
		<div class="base-grid">
			<div
				class="col-start-2 col-end-12 lg:col-start-3 lg:col-end-11 2xl:col-start-4 2xl:col-end-10 grid grid-cols-1 gap-4 md:grid-cols-2 items-end"
			>
				<WorkCard
					href="/work/gtm"
					image="/images/mountain.avif"
					title="Go To Market"
					description="Not a launch plan. The system that makes product, marketing, and sales compound as one."
					label="Explore GTM"
				/>
				<WorkCard
					href="/work/marketing"
					image="/images/mist.avif"
					title="Marketing"
					description="Not louder. Remarkable. Marketing that earns trust, not just attention."
					label="Explore marketing"
				/>
			</div>
		</div>
	</section>

	<ContactFooter />
</BaseLayout>
