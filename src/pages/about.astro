---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactFooter from "@/components/ContactFooter.astro";
import ArrowLink from "@/components/ArrowLink.astro";
import { getT } from "@/i18n/getT";

const t = getT(Astro.currentLocale);
---

<BaseLayout
	title={t("about.title", "Jan Vítů — About")}
	description={t(
		"about.description",
		"Curious by nature, relentless about outcomes. I help brands find focus, build the right strategy, and turn ambitious ideas into measurable results.",
	)}
>
	<section class="relative h-screen">
		<div class="grid grid-cols-12 pt-[38vh] pb-[10vh]">
			<h1
				class="col-start-2 flex-nowrap whitespace-nowrap font-normal md:col-start-3"
			>
				Nice to meet you<br />
				<span class="font-black text-neutral-900">
					I'm <span class="text-accent">Jan</span>
				</span>
			</h1>
			<p
				class="col-start-3 col-end-12 row-start-2 mt-4 text-2xl text-neutral-700 sm:text-3xl md:col-start-4 md:col-end-11 md:mt-10 md:text-4xl xl:text-5xl"
			>
				Great work isn't about louder ideas.<br />
				<b class="text-neutral-900"
					>It's about <span class="text-accent">sharper</span> focus.</b
				>
			</p>
			<p
				class="col-start-3 col-end-12 row-start-3 mt-2 text-sm text-neutral-600 sm:text-base md:col-start-4 md:col-end-10 md:mt-5 md:text-xl"
			>
				I believe growth happens when curiosity meets discipline and when ambition is
				grounded in clarity.
			</p>
		</div>
	</section>

	<section>
		<div class="base-grid py-14 md:py-32">
			<h2
				class="col-start-2 whitespace-nowrap md:col-start-4"
			>
				The space between <b>ideas</b><br />
				and <span class="text-accent">outcomes</span>
			</h2>
			<p
				class="col-start-3 col-end-12 row-start-2 mt-4 text-xl text-neutral-700 sm:text-2xl md:col-start-5 md:col-end-10 md:mt-10 md:text-3xl lg:col-end-10"
			>
				Ideas are easy.
				<br />Making them work? That's the hard part.
			</p>
			<div
				class="mt-6 col-start-3 col-end-12 row-start-3 md:col-start-5 lg:col-end-10 space-y-2 md:space-y-4"
			>
				<p class="text-sm text-neutral-700 sm:text-base md:text-xl">
					I'm drawn to the moment when an idea becomes real. When something
					abstract starts to move people.
				</p>
				<p class="text-sm text-neutral-700 sm:text-base md:text-xl">
					Growth doesn't come from noise or luck. It comes from focus, testing,
					and the courage to change what fails.
				</p>
				<p class="text-sm text-neutral-700 sm:text-base md:text-xl">
					That tension between exploring and committing became my framework for
					everything I do.
				</p>
			</div>

			<div
				class="col-start-2 row-start-5 mt-5 whitespace-nowrap sm:col-start-4 md:col-start-5 md:mt-10 md:text-3xl"
			>
				<ArrowLink href="/contact" label="Let's work together" />
			</div>
		</div>
	</section>

	<section id="process">
		<div class="base-grid pt-24 pb-10 md:pt-32">
			<h2
				class="col-start-2 whitespace-nowrap md:col-start-4"
			>
				Where <b>strategy</b> <br />becomes
				<span class="text-accent">traction</span>
			</h2>
			<p
				class="col-start-3 col-end-12 row-start-2 mt-4 text-xl text-neutral-700 sm:text-2xl md:col-start-5 md:col-end-10 md:mt-10 md:text-3xl lg:col-end-9"
			>
				Insight creates direction.<br />People create momentum.
			</p>
			<div
				class="mt-6 col-start-3 col-end-12 row-start-3 md:col-start-5 lg:col-end-10 space-y-2 md:space-y-4"
			>
				<p class="text-sm text-neutral-700 sm:text-base md:text-xl">
					Strategy doesn't move on its own.
					It moves when people understand why it matters.
				</p>
				<p class="text-sm text-neutral-700 sm:text-base md:text-xl">
					When the mission is clear and the insight is sharp,
					teams stop executing tasks and start driving change.
				</p>
				<p class="text-sm text-neutral-700 sm:text-base md:text-xl">
					That's when strategy becomes traction.
				</p>
			</div>

			<div
				class="col-start-2 col-end-12 mt-8 grid grid-flow-row items-center overflow-x-hidden md:mt-20 md:grid-cols-3"
			>
				<span class="mx-auto text-2xl font-bold uppercase md:ml-auto md:mr-8">
					Insight
				</span>
				<svg
					width="100%"
					height="100%"
					class="min-h-[50vh] rotate-90 md:min-h-0 md:rotate-0"
					xmlns="http://www.w3.org/2000/svg"
					xmlns:xlink="http://www.w3.org/1999/xlink"
					viewBox="0 0 706 526"
				>
					<defs>
						<style>
							.cls-1 {
								fill: url(#linear-gradient);
							}

							.cls-1,
							.cls-2 {
								stroke-width: 0px;
							}

							.cls-2 {
								fill: url(#gradient);
							}
						</style>
						<linearGradient
							id="linear-gradient"
							x1="0"
							y1="313"
							x2="706"
							y2="313"
							gradientUnits="userSpaceOnUse"
						>
							<stop offset="0" style="stop-color: var(--color-accent)"></stop>
							<stop offset=".1" style="stop-color: var(--color-accent)" stop-opacity=".04"></stop>
							<stop offset=".71" style="stop-color: var(--color-accent)" stop-opacity=".4"></stop>
							<stop offset="1" style="stop-color: var(--color-accent)"></stop>
						</linearGradient>
						<linearGradient
							id="gradient"
							x1="0"
							y1="213"
							x2="706"
							y2="213"
							gradientUnits="userSpaceOnUse"
						>
							<stop offset="0" style="stop-color: var(--color-accent)"></stop>
							<stop offset=".29" style="stop-color: var(--color-accent)" stop-opacity=".4"></stop>
							<stop offset=".9" style="stop-color: var(--color-accent)" stop-opacity=".04"></stop>
							<stop offset="1" style="stop-color: var(--color-accent)"></stop>
						</linearGradient>
					</defs>
					<g id="Layer_2-2" data-name="Layer 2">
						<g>
							<path
								class="cls-1"
								d="M353,526c-88.68,0-172.87-18.86-237.07-53.09-34.01-18.14-61.22-39.91-80.88-64.69C12.12,379.29,0,346.37,0,313v-100h6c0,16.49,3.1,32.95,9.21,48.93,4.41,11.55,10.41,22.83,17.83,33.51,2.15,3.11,4.4,6.15,6.7,9.04,19.15,24.14,45.73,45.38,79,63.13,62.48,33.32,144.49,51.92,230.93,52.38,2.22.02,4.42.02,6.62,0,69.31-.46,136.33-15.26,183.88-40.62,37.45-19.97,59.81-44.78,59.81-66.37,0-14.93-10.96-31.86-30.85-47.65-8.29-6.59-18.04-12.89-28.97-18.72-48.41-25.82-116.64-40.63-187.19-40.63s-138.77,14.81-187.19,40.63c-10.93,5.84-20.68,12.14-28.97,18.72l-1.87,1.48-1.87-1.48c-21.35-16.95-33.12-35.54-33.12-52.35,0-23.84,23.55-50.63,62.99-71.67,48.39-25.8,116.42-40.86,186.66-41.32,2.22-.02,4.47-.02,6.71,0,87.39.46,170.4,19.32,233.72,53.09,34.01,18.14,61.22,39.9,80.88,64.68,2.38,2.99,4.71,6.14,6.94,9.36,7.69,11.08,13.92,22.78,18.5,34.79,6.38,16.66,9.61,33.84,9.61,51.07,0,33.37-12.12,66.29-35.05,95.21-19.65,24.78-46.86,46.54-80.88,64.69-64.2,34.24-148.39,53.09-237.07,53.09ZM6,253.48v59.52c0,32,11.67,63.64,33.75,91.49,19.14,24.14,45.72,45.38,79,63.13,63.34,33.78,146.53,52.39,234.25,52.39s170.9-18.6,234.25-52.39c33.29-17.76,59.87-39,79-63.13,22.08-27.85,33.75-59.49,33.75-91.49,0-16.49-3.1-32.95-9.21-48.93-4.41-11.55-10.41-22.83-17.83-33.51-2.15-3.11-4.41-6.15-6.71-9.04-19.14-24.14-45.72-45.37-79-63.12-62.47-33.33-144.49-51.93-230.93-52.39-2.22-.02-4.42-.02-6.62,0-69.31.46-136.33,15.26-183.88,40.62-37.45,19.98-59.81,44.79-59.81,66.37,0,14.48,10.28,30.81,29.01,46.17,8.15-6.27,17.55-12.26,27.98-17.84,49.26-26.27,118.51-41.33,190.01-41.33s140.75,15.07,190.01,41.33c11.25,6.01,21.3,12.51,29.87,19.32,21.35,16.96,33.11,35.55,33.11,52.35,0,23.85-23.55,50.64-62.99,71.67-48.38,25.8-116.42,40.86-186.66,41.32-2.22.02-4.47.02-6.71,0-87.39-.46-170.39-19.31-233.72-53.08-34.01-18.14-61.22-39.91-80.88-64.69-2.38-3-4.72-6.15-6.94-9.36-7.69-11.08-13.92-22.78-18.51-34.79-1.34-3.51-2.54-7.04-3.61-10.59Z"
							></path>
							<path
								class="cls-2"
								d="M353,426c-1.12,0-2.24,0-3.36,0-87.39-.46-170.39-19.31-233.72-53.08-34.01-18.14-61.22-39.91-80.88-64.69-2.38-3-4.72-6.15-6.94-9.36-7.69-11.08-13.92-22.78-18.51-34.79C3.23,247.41,0,230.23,0,213c0-33.37,12.12-66.29,35.05-95.21,19.66-24.79,46.87-46.55,80.88-64.68C180.12,18.86,264.31,0,353,0s172.88,18.86,237.07,53.1c34.01,18.14,61.22,39.9,80.88,64.68,22.93,28.92,35.05,61.85,35.05,95.21v100h-6c0-16.49-3.1-32.95-9.21-48.93-4.41-11.55-10.41-22.83-17.83-33.51-2.15-3.11-4.41-6.15-6.71-9.04-19.14-24.14-45.72-45.37-79-63.12-62.47-33.33-144.49-51.93-230.93-52.39-2.22-.02-4.42-.02-6.62,0-69.31.46-136.33,15.26-183.88,40.62-37.45,19.98-59.81,44.79-59.81,66.37,0,14.94,10.95,31.87,30.84,47.65,8.33,6.61,18.07,12.91,28.97,18.72,48.42,25.82,116.64,40.63,187.19,40.63s138.77-14.81,187.19-40.63c10.89-5.81,20.64-12.11,28.96-18.72l1.87-1.48,1.87,1.48c21.35,16.96,33.12,35.55,33.12,52.35,0,23.85-23.55,50.64-62.99,71.67-48.38,25.8-116.42,40.86-186.66,41.32-1.11,0-2.23,0-3.35,0ZM353,6c-87.72,0-170.91,18.61-234.25,52.4-33.27,17.74-59.85,38.98-79,63.12-22.08,27.85-33.75,59.48-33.75,91.49,0,16.49,3.1,32.95,9.21,48.93,4.41,11.55,10.41,22.83,17.83,33.51,2.15,3.11,4.4,6.15,6.7,9.04,19.15,24.14,45.73,45.38,79,63.13,62.48,33.32,144.49,51.92,230.93,52.38,2.22.02,4.42.02,6.62,0,69.31-.46,136.33-15.26,183.88-40.62,37.45-19.97,59.81-44.78,59.81-66.37,0-14.47-10.28-30.8-29.01-46.17-8.18,6.3-17.58,12.29-27.98,17.84-49.26,26.27-118.51,41.33-190.01,41.33s-140.75-15.07-190.01-41.33c-11.22-5.98-21.27-12.48-29.87-19.32-21.35-16.94-33.11-35.54-33.11-52.35,0-23.84,23.55-50.63,62.99-71.67,48.39-25.8,116.42-40.86,186.66-41.32,2.22-.02,4.47-.02,6.71,0,87.39.46,170.4,19.32,233.72,53.09,34.01,18.14,61.22,39.9,80.88,64.68,2.38,2.99,4.71,6.14,6.94,9.36,7.69,11.08,13.92,22.78,18.5,34.79,1.34,3.51,2.54,7.04,3.61,10.59v-59.52c0-32-11.67-63.64-33.75-91.49-19.14-24.13-45.72-45.37-79-63.12C523.91,24.61,440.72,6,353,6Z"
							></path>
						</g>
					</g>
				</svg>
				<span class="mx-auto text-2xl font-bold uppercase md:mr-auto md:ml-8">
					Impact
				</span>
			</div>
		</div>
	</section>

	<section>
		<div class="base-grid py-14 md:py-32">
			<h2
				class="col-start-2 whitespace-nowrap md:col-start-4"
			>
				Turning <b>clarity</b> into <span class="text-accent">momentum</span>
			</h2>
			<p
				class="col-start-2 col-end-12 row-start-2 mt-4 text-xl text-neutral-700 sm:text-2xl md:col-start-4 md:col-end-9 md:mt-10 md:text-3xl"
			>
				Behind every project is the same goal.
			</p>
			<div
				class="col-start-2 col-end-12 row-start-3 md:col-start-4 lg:col-end-8 xl:col-end-9"
			>
				<p
					class="mt-2 text-sm text-neutral-700 sm:text-base md:mt-5 md:text-xl italic"
				>
					To make decisions easier and results measurable. It's less about
					tactics, more about systems that help teams think, act, and improve
					faster.
				</p>
				<p class="mt-2 text-sm text-neutral-700 sm:text-base md:mt-5 md:text-xl">
					Clarity doesn't slow things down. It makes progress visible, repeatable,
					and scalable.
				</p>
			</div>
		</div>
	</section>

	<section>
		<div class="base-grid py-14 md:py-32">
			<h2
				class="col-start-2 whitespace-nowrap font-semibold md:col-start-4"
			>
				What
				<br /><span class="ml-4 md:ml-10">drives me</span>
			</h2>
			<div class="col-start-2 col-end-12 grid md:col-start-4 md:col-end-10 mt-32">
				<div class="relative w-full">
					<div data-glossary-toggle>
						<div data-glossary-title>
							<span
								class="absolute left-[50%] -top-[13%] text-[clamp(0.75rem,2vw,1.5rem)] font-medium text-accent select-none md:select-auto italic"
							>
								Courage & Boldness*
							</span>
						</div>
						<div
							data-glossary
							class="fixed top-0 left-0 bottom-0 right-0 bg-white/60 backdrop-blur-xs z-[1100] px-[8.33%] flex flex-col justify-end md:justify-center pb-10"
						>
							<span class="text-xl md:text-2xl"
								>Dare to chase ideas, take risks, and push limits.</span
							>
						</div>
					</div>
					<div data-glossary-toggle>
						<div data-glossary-title>
							<span
								class="absolute -right-[6%] md:left-[85%] top-[37%] text-[clamp(0.75rem,2vw,1.5rem)] font-medium text-accent select-none md:select-auto italic text-nowrap"
							>
								Unconventional perspective*
							</span>
						</div>
						<div
							data-glossary
							class="fixed top-0 left-0 bottom-0 right-0 bg-white/60 backdrop-blur-xs z-[1100] px-[8.33%] flex flex-col justify-end md:justify-center pb-10"
						>
							<span class="text-xl md:text-2xl"
								>Embrace the unexpected, see opportunities in flaws.</span
							>
						</div>
					</div>
					<div data-glossary-toggle>
						<div data-glossary-title>
							<span
								class="absolute left-[75%] top-[98%] text-[clamp(0.75rem,2vw,1.5rem)] font-medium text-accent select-none md:select-auto italic"
							>
								No bullshit*
							</span>
						</div>
						<div
							data-glossary
							class="fixed top-0 left-0 bottom-0 right-0 bg-white/60 backdrop-blur-xs z-[1100] px-[8.33%] flex flex-col justify-end md:justify-center pb-10"
						>
							<span class="text-xl md:text-2xl"
								>Be real, clear, and honest. Say it as it is.</span
							>
						</div>
					</div>
					<div data-glossary-toggle>
						<div data-glossary-title>
							<span
								class="absolute left-[15%] top-[105%] text-[clamp(0.75rem,2vw,1.5rem)] font-medium text-accent select-none md:select-auto italic"
							>
								Infinite mindset*
							</span>
						</div>
						<div
							data-glossary
							class="fixed top-0 left-0 bottom-0 right-0 bg-white/60 backdrop-blur-xs z-[1100] px-[8.33%] flex flex-col justify-end md:justify-center pb-10"
						>
							<span class="text-xl md:text-2xl">
								Strive for constant growth, build lasting value, and keep moving
								towards the bigger vision.
							</span>
						</div>
					</div>
					<div data-glossary-toggle>
						<div data-glossary-title>
							<span
								class="absolute -left-[5%] top-[12%] text-[clamp(0.75rem,2vw,1.5rem)] font-medium text-accent select-none md:select-auto italic"
							>
								Simplicity*
							</span>
						</div>
						<div
							data-glossary
							class="fixed top-0 left-0 bottom-0 right-0 bg-white/60 backdrop-blur-xs z-[1100] px-[8.33%] flex flex-col justify-end md:justify-center pb-10"
						>
							<span class="text-xl md:text-2xl"
								>Clarity over complexity. Simple ideas move faster and
								further.</span
							>
						</div>
					</div>
					<div>
						<img
							src="/images/star.avif"
							alt=""
							aria-hidden="true"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<ContactFooter />
</BaseLayout>
