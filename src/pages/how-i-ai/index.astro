---
import HowIAiLayout from "../../layouts/HowIAiLayout.astro";
import TerminalFrame from "../../components/TerminalFrame.astro";
---

<HowIAiLayout
	title="How I AI"
	description="How Jan uses AI in his product management workflow."
>
	<TerminalFrame>
		<!-- Tab panel: My Stack (active by default) -->
		<div
			role="tabpanel"
			id="panel-my-stack"
			aria-labelledby="tab-my-stack"
			class="tab-panel"
			data-tab-id="my-stack"
		>
			<h2>AI Models</h2>
			<ul>
				<li>
					<strong>Claude Opus 4</strong> -- complex reasoning, architecture decisions,
					deep analysis
				</li>
				<li>
					<strong>Claude Sonnet</strong> -- drafting, fast iteration, code review
				</li>
				<li>
					<strong>Cursor</strong> -- inline code generation and editing
				</li>
			</ul>
			<h2>Integrations</h2>
			<ul>
				<li>
					<strong>Claude Code</strong> -- CLI-based agentic coding in the terminal
				</li>
				<li>
					<strong>n8n</strong> -- workflow automation, self-hosted
				</li>
				<li>
					<strong>Notion</strong> -- knowledge base and documentation
				</li>
			</ul>
		</div>

		<!-- Tab panel: Setup -->
		<div
			role="tabpanel"
			id="panel-setup"
			aria-labelledby="tab-setup"
			class="tab-panel"
			data-tab-id="setup"
			hidden
		>
			<h2>Environment</h2>
			<ul>
				<li>MacBook Pro -- primary development machine</li>
				<li>Terminal-first workflow -- iTerm2 + tmux</li>
			</ul>
			<h2>Key Tools</h2>
			<ul>
				<li>
					<strong>Claude Code CLI</strong> -- agentic coding directly in the terminal
				</li>
				<li>
					<strong>Cursor IDE</strong> -- AI-augmented editor for larger projects
				</li>
				<li>
					<strong>n8n</strong> -- self-hosted automation for repetitive PM tasks
				</li>
			</ul>
			<h2>Configuration</h2>
			<p>
				Custom dotfiles, shell aliases for common AI workflows, and
				project-specific CLAUDE.md instruction files that shape how Claude
				behaves per repository.
			</p>
		</div>

		<!-- Tab panel: Workflow -->
		<div
			role="tabpanel"
			id="panel-workflow"
			aria-labelledby="tab-workflow"
			class="tab-panel"
			data-tab-id="workflow"
			hidden
		>
			<h2>Daily Loop</h2>
			<ul>
				<li>
					<strong>Morning context briefing</strong> -- catch up on overnight changes
					with AI-summarized diffs
				</li>
				<li>
					<strong>PM artifact drafts</strong> -- PRDs, specs, and user stories co-written
					with Claude
				</li>
				<li>
					<strong>Spec review</strong> -- AI-assisted review for completeness and edge
					cases
				</li>
			</ul>
			<h2>Recurring Patterns</h2>
			<ul>
				<li>
					Prompt patterns for PRDs -- structured templates that produce consistent
					output
				</li>
				<li>
					User story refinement -- iterative sharpening with Claude as sparring
					partner
				</li>
				<li>
					Retro synthesis -- extracting action items from retrospective notes
				</li>
			</ul>
		</div>

		<!-- Tab panel: Tips -->
		<div
			role="tabpanel"
			id="panel-tips"
			aria-labelledby="tab-tips"
			class="tab-panel"
			data-tab-id="tips"
			hidden
		>
			<h2>What Works</h2>
			<ul>
				<li>
					<strong>Give Claude full context</strong> -- the more background, the better
					the output. Include goals, constraints, and audience.
				</li>
				<li>
					<strong>Treat it as a senior collaborator</strong> -- ask for critique, not
					just generation. Push back on suggestions.
				</li>
				<li>
					<strong>Iterate in conversation</strong> -- refine outputs through multiple
					turns rather than trying to get it perfect in one shot.
				</li>
			</ul>
			<h2>What Doesn't</h2>
			<ul>
				<li>
					<strong>One-shot complex specs</strong> -- long, detailed documents need iterative
					co-creation, not a single prompt.
				</li>
				<li>
					<strong>Skipping review</strong> -- AI output always needs human judgment.
					Trust but verify.
				</li>
			</ul>
		</div>
	</TerminalFrame>
</HowIAiLayout>
