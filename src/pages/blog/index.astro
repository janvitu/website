---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogCategoryNav from "@/components/BlogCategoryNav.astro";
import ArticlePreview from "@/components/ArticlePreview.astro";
import { useT } from "@/i18n/getT";
import { getPublishedPosts } from "@/lib/blog";

const t = useT(Astro);
const posts = await getPublishedPosts();
const [featured, ...rest] = posts;
const currentPath = Astro.url.pathname;
---

<BaseLayout title={t("blog.title", "Blog — Jan Vítů")}>
	<BlogCategoryNav currentPath={currentPath} />

	<div class="pt-14 md:pt-20">
		<div class="base-grid">
			{
				featured && (
					<div class="col-span-full">
						<div class="base-grid">
							<p class="col-start-2 col-end-12 py-6 text-lg font-bold uppercase md:col-start-3 md:col-end-11 md:py-10">
								{t("blog.featured", "Featured")}
							</p>
						</div>
						<ArticlePreview entry={featured} isFirst />
					</div>
				)
			}

			{
				rest.length > 0 && (
					<div class="col-span-full">
						<div class="base-grid">
							<p class="col-start-2 col-end-12 py-6 text-lg font-bold uppercase md:col-start-3 md:col-end-11 md:py-10">
								{t("blog.latestPosts", "Latest posts")}
							</p>
						</div>
						{rest.map((post) => (
							<ArticlePreview entry={post} />
						))}
					</div>
				)
			}

			{
				posts.length === 0 && (
					<p class="col-start-2 col-end-12 text-neutral-500">No posts yet.</p>
				)
			}
		</div>
	</div>
</BaseLayout>
